NODE_ENV=development
PORT=5000

# MongoDB connection string (local example)
MONGODB_URI=mongodb://127.0.0.1:27017/gasolink

# Use a long random secret (>= 20 chars)
JWT_SECRET=replace-with-a-long-random-secret

# Vite dev server origin(s), comma-separated
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Optional seed admin override
SEED_ADMIN_EMAIL=admin@gasolink.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# Redis (BullMQ queue)
REDIS_URL=redis://127.0.0.1:6379

# Source selection (default: all)
# all: run all configured sources
# doe_only: run only sources with sourceType=official_local (DOE)
SOURCES_MODE=all

# Schedules (cron strings). These are safe defaults; tune in production.
SCHEDULE_GLOBAL_FETCH=*/5 * * * *
SCHEDULE_PH_OFFICIAL=15 */1 * * *
SCHEDULE_PH_COMPANY=*/30 * * * *
SCHEDULE_PH_OBSERVED=45 */1 * * *
SCHEDULE_RECONCILE=*/10 * * * *
SCHEDULE_DATA_QUALITY=*/15 * * * *

