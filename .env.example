NODE_ENV=development
PORT=5000

# MongoDB connection string (local example)
MONGODB_URI=mongodb://127.0.0.1:27017/gasolink

# Use a long random secret (>= 20 chars)
JWT_SECRET=replace-with-a-long-random-secret

# Vite dev server origin(s), comma-separated
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Optional seed admin override
SEED_ADMIN_EMAIL=admin@gasolink.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# Redis (BullMQ queue)
REDIS_URL=redis://127.0.0.1:6379

# Schedules (cron strings). These are safe defaults; tune in production.
SCHEDULE_GLOBAL_FETCH=*/5 * * * *
# AI search cadence (recommended every 1-3 hours)
SCHEDULE_AI_INGESTION=0 */2 * * *
SCHEDULE_DATA_QUALITY=*/15 * * * *
SCHEDULE_AI_ESTIMATION=0 */2 * * *
ENABLE_NEW_ESTIMATOR=true

# Groq AI
GROQ_API_KEY=replace_me
GROQ_MODEL=llama-3.3-70b-versatile

# Serper.dev Search API
SERPER_API_KEY=replace_me

